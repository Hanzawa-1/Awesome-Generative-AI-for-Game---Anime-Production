# Copy to .env (git-ignored) for local runs. Fill in the key for your chosen provider.

# Which backend the agent uses: "gemini" | "openrouter"
LLM_PROVIDER=gemini-3.5-flash

# Optional model override (defaults: gemini-2.5-flash / google/gemini-2.5-flash).
# Do NOT trust aspirational version numbers — set to a model id you've confirmed exists.
# LLM_MODEL=gemini-2.5-flash

# Provider keys (only the one matching LLM_PROVIDER is required)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional: raises Hugging Face rate limits (read-only is fine without it)
HF_TOKEN=

# Optional: a GitHub PAT for the search_github tool when running locally.
# In GitHub Actions this is provided automatically as GITHUB_TOKEN.
GITHUB_TOKEN=

# Agent budgets (optional overrides)
# AGENT_MAX_ITERS=12
# AGENT_MAX_TOOL_CALLS=40
# AGENT_MAX_NEW_ENTRIES=20
# AGENT_MAX_TOKENS=200000
# AGENT_WALL_CLOCK_SECONDS=1200